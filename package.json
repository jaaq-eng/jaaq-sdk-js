{
  "name": "@jaaq/jaaq-sdk-js",
  "version": "1.1.1",
  "description": "Official JavaScript SDK for JAAQ API",
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "scripts": {
    "build": "rollup -c",
    "dev": "dotenvx run -f .env.development -- rollup -c --watch",
    "build:dev": "dotenvx run -f .env.development -- rollup -c",
    "build:staging": "dotenvx run -f .env.staging -- rollup -c",
    "build:prod": "dotenvx run -f .env.production -- rollup -c",
    "build:local": "JAAQ_CDN_URL=http://localhost:9999 NODE_ENV=development rollup -c",
    "test": "vitest run --exclude=tests/build",
    "test:watch": "vitest --exclude=tests/build",
    "test:coverage": "vitest run --coverage --exclude=tests/build",
    "test:coverage:watch": "vitest --coverage --exclude=tests/build",
    "test:smoke:dev": "dotenvx run -f .env.development -- vitest run tests/build",
    "test:smoke:staging": "dotenvx run -f .env.staging -- vitest run tests/build",
    "test:smoke:prod": "dotenvx run -f .env.production -- vitest run tests/build",
    "test:smoke:ci": "vitest run tests/build",
    "check-paths-in-bundle": "grep -R -nE --exclude='*.map' '@core/|@resources/' dist || echo 'OK no aliases found'",
    "openapi:gen": "openapi-typescript ./openapi.json -o ./src/gen/openapi.ts",
    "audit:moderate": "pnpm audit --audit-level=moderate",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "prepare": "husky"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs",
      "default": "./dist/index.mjs"
    },
    "./ui": {
      "types": "./dist/ui/index.d.ts",
      "import": "./dist/ui/index.mjs",
      "require": "./dist/ui/index.cjs",
      "default": "./dist/ui/index.mjs"
    },
    "./ui/react": {
      "types": "./dist/ui/react/index.d.ts",
      "import": "./dist/ui/react/index.mjs",
      "require": "./dist/ui/react/index.cjs",
      "default": "./dist/ui/react/index.mjs"
    },
    "./ui/webcomponents": {
      "types": "./dist/ui/webcomponents/index.d.ts",
      "import": "./dist/ui/webcomponents/index.mjs",
      "require": "./dist/ui/webcomponents/index.cjs",
      "default": "./dist/ui/webcomponents/index.mjs"
    }
  },
  "keywords": [
    "jaaq",
    "sdk",
    "api",
    "video",
    "collections"
  ],
  "author": "JAAQ",
  "license": "ISC",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/jaaq-eng/jaaq-sdk-js.git"
  },
  "bugs": {
    "url": "https://github.com/jaaq-eng/jaaq-sdk-js/issues"
  },
  "homepage": "https://github.com/jaaq-eng/jaaq-sdk-js#readme",
  "publishConfig": {
    "access": "public"
  },
  "packageManager": "pnpm@11.1.3",
  "engines": {
    "node": ">=22"
  },
  "lint-staged": {
    "*.{ts,tsx,js}": [
      "eslint --fix --max-warnings=0"
    ],
    "*.{json,md,yml,yaml,ts,tsx,js}": [
      "prettier --write"
    ]
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "dependencies": {
    "@splidejs/splide": "4.1.4",
    "hls.js": "1.6.16"
  },
  "peerDependencies": {
    "react": "^18.0.0 || ^19.0.0",
    "react-dom": "^18.0.0 || ^19.0.0"
  },
  "peerDependenciesMeta": {
    "react": {
      "optional": true
    },
    "react-dom": {
      "optional": true
    }
  },
  "devDependencies": {
    "@commitlint/cli": "20.5.3",
    "@commitlint/config-conventional": "20.5.3",
    "@dotenvx/dotenvx": "1.65.0",
    "@eslint/js": "10.0.1",
    "@rollup/plugin-commonjs": "29.0.2",
    "@rollup/plugin-node-resolve": "16.0.3",
    "@rollup/plugin-replace": "6.0.3",
    "@rollup/plugin-terser": "1.0.0",
    "@rollup/plugin-typescript": "12.3.0",
    "@types/hls.js": "1.0.0",
    "@types/node": "25.6.2",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@typescript-eslint/eslint-plugin": "8.60.0",
    "@typescript-eslint/parser": "8.60.0",
    "@vitest/coverage-v8": "4.1.5",
    "eslint": "10.4.0",
    "eslint-config-prettier": "10.1.8",
    "globals": "17.6.0",
    "husky": "9.1.7",
    "lint-staged": "17.0.5",
    "msw": "2.14.6",
    "openapi-typescript": "7.13.0",
    "prettier": "3.8.3",
    "react": "19.2.6",
    "react-dom": "19.2.6",
    "rollup": "4.60.3",
    "rollup-plugin-dts": "6.4.1",
    "rollup-plugin-tsconfig-paths": "1.5.2",
    "tslib": "2.8.1",
    "typescript": "5.9.3",
    "vitest": "4.1.5"
  }
}
